{
  "name": "@ultracoder/cli",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@ultracoder/core": "workspace:*",
    "@ultracoder/experiment": "workspace:*",
    "@ultracoder/issue-monitor": "workspace:*",
    "@ultracoder/quality": "workspace:*",
    "@ultracoder/plugin-runtime-tmux": "workspace:*",
    "@ultracoder/plugin-runtime-process": "workspace:*",
    "@ultracoder/plugin-runtime-docker": "workspace:*",
    "@ultracoder/plugin-agent-claude-code": "workspace:*",
    "@ultracoder/plugin-agent-codex": "workspace:*",
    "@ultracoder/plugin-workspace-worktree": "workspace:*",
    "@ultracoder/plugin-workspace-clone": "workspace:*",
    "@ultracoder/plugin-tracker-github": "workspace:*",
    "@ultracoder/plugin-scm-github": "workspace:*",
    "@ultracoder/plugin-notifier-desktop": "workspace:*",
    "@ultracoder/plugin-notifier-slack": "workspace:*",
    "@ultracoder/plugin-terminal-web": "workspace:*",
    "commander": "^12.1.0"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "bin": {
    "uc": "dist/bin.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TaisoAI/taiso-ultracoder.git",
